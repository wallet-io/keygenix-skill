# Keygenix Configuration
# Copy this to .env and fill in your values

# ── API Auth Keypair ──────────────────────────────────────────────────────────
# Generated with: node client.js keygen
# Register the PUBLIC key on keygenix.pro dashboard
KEYGENIX_API_PRIV_KEY=<your_api_auth_private_key_hex>
KEYGENIX_API_PUB_KEY=<your_api_auth_public_key_hex>

# ── AuthKey Keypair ───────────────────────────────────────────────────────────
# A SEPARATE keypair — controls sign/export authorization
# Register authPubKey when creating/importing keys via API
KEYGENIX_AUTH_PRIV_KEY=<your_authkey_private_key_hex>
KEYGENIX_AUTH_PUB_KEY=<your_authkey_public_key_hex>

# ── Organization & Wallet ─────────────────────────────────────────────────────
# From your keygenix.pro dashboard
KEYGENIX_ORG_CODE=<your_org_code>
KEYGENIX_WALLET_CODE=<your_wallet_code>
